{
  "name": "claude-launcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:rust": "cd src-tauri && cargo test",
    "test:e2e": "npm run build && npm run tauri build && wdio run wdio.conf.js",
    "test:e2e:dev": "wdio run wdio.conf.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\""
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^6.0.0",
    "@mui/lab": "^6.0.0-beta.0",
    "@mui/material": "^6.0.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-log": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@tauri-apps/api": "^2.6.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/eslint-plugin": "^1.5.1",
    "@vitest/ui": "^2.1.8",
    "@wdio/cli": "^9.17.1",
    "@wdio/local-runner": "^9.17.0",
    "@wdio/mocha-framework": "^9.17.0",
    "@wdio/spec-reporter": "^9.17.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^17.6.1",
    "prettier": "^3.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "webdriverio": "^9.17.0"
  },
  "description": "Claude Code Launcher - A Windows desktop app for managing and launching Claude Code projects",
  "main": "vite.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "@testing-library/dom": "9.3.4"
  }
}
