// Mock @mui/icons-material
vi.mock('@mui/icons-material', () => ({
  Add: () => 'AddIcon',
  Search: () => 'SearchIcon',
  DarkMode: () => 'DarkModeIcon',
  LightMode: () => 'LightModeIcon',
  Refresh: () => 'RefreshIcon',
  Clear: () => 'ClearIcon',
  Sort: () => 'SortIcon',
  Star: () => 'StarIcon',
  StarBorder: () => 'StarBorderIcon',
  Launch: () => 'LaunchIcon',
  Edit: () => 'EditIcon',
  Delete: () => 'DeleteIcon',
  Folder: () => 'FolderIcon',
  Check: () => 'CheckIcon',
  Close: () => 'CloseIcon',
  Notes: () => 'NotesIcon',
  Palette: () => 'PaletteIcon',
}));

// Clear all mocks after each test
afterEach(() => {
  // Individual tests will call clearMocks when needed
});

// Mock console methods that might be noisy in tests
global.console = {
  ...console,
  // Keep error and warn for debugging test failures
  error: console.error,
  warn: console.warn,
  // Silence info and debug logs unless debugging
  info: vi.fn(),
  debug: vi.fn(),
  log: vi.fn(),
};

// Mock window.matchMedia
Object.defineProperty(window, 'matchMedia', {
  writable: true,
  value: vi.fn().mockImplementation(query => ({
    matches: false,
    media: query,
    onchange: null,
    addListener: vi.fn(), // deprecated
    removeListener: vi.fn(), // deprecated
    addEventListener: vi.fn(),
    removeEventListener: vi.fn(),
    dispatchEvent: vi.fn(),
  })),
});

// Mock IntersectionObserver
global.IntersectionObserver = vi.fn().mockImplementation(() => ({
  observe: vi.fn(),
  unobserve: vi.fn(),
  disconnect: vi.fn(),
}));

// Mock ResizeObserver
global.ResizeObserver = vi.fn().mockImplementation(() => ({
  observe: vi.fn(),
  unobserve: vi.fn(),
  disconnect: vi.fn(),
}));