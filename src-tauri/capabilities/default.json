{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the Claude Launcher main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:window:default",
    "core:window:allow-close",
    "core:webview:default",
    "core:webview:allow-webview-close",
    "opener:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "window-state:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claude-code",
          "cmd": "claude-code",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-cli",
          "cmd": "claude-cli",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
