{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the Claude Launcher main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "opener:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claude-code",
          "cmd": "claude-code",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-cli",
          "cmd": "claude-cli",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
